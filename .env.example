# Example .env file — copy to .env and fill in your cluster details
# The head node should be the DGX Spark with the most disk space (4TB model)

# Comma-separated list of all DGX Spark node IPs
CLUSTER_NODES=<HEAD_IP>,<WORKER_1_IP>,<WORKER_2_IP>

# Head node IP (must be the first IP in CLUSTER_NODES)
LOCAL_IP=<HEAD_IP>

# Network interfaces (auto-detected on NVIDIA DGX Spark)
ETH_IF=enP7s7
IB_IF=rocep1s0f0,rocep1s0f1

# Ray head port
MASTER_PORT=29519

# Docker container name
CONTAINER_NAME=vllm_ds4

# HuggingFace cache (inside container)
CONTAINER_HF_HOME=/root/.cache/huggingface
CONTAINER_HF_HUB_OFFLINE=1
CONTAINER_TRANSFORMERS_OFFLINE=1

# NCCL configuration (Socket transport — IB/RoCE requires switch-level config)
CONTAINER_NCCL_NET_PLUGIN=none
CONTAINER_NCCL_IB_SUBNET_AWARE_ROUTING=1
CONTAINER_NCCL_IB_MERGE_NICS=0
CONTAINER_NCCL_IB_GID_INDEX=3
CONTAINER_NCCL_IB_DISABLE=1
CONTAINER_NCCL_SOCKET_IFNAME=enP7s7

# Ray compiled graph timeout (seconds) — must be high enough for MoE init
CONTAINER_RAY_CGRAPH_get_timeout=3600
